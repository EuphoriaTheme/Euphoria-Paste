{
  "env": {
    "es6": true,
    "node": true,
    "mocha": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "extends": "eslint:recommended",
  "rules": {
    "no-constant-condition": "off",
    "quotes": ["error", "single"],
    "semi": ["error", "always"]
  }
}
